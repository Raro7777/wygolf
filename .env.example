NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Turbopack/플레이스홀더 이슈·Cursor 등에서 NEXT_PUBLIC_* 가 이미 설정된 경우 next.config 가 .env 파일에서 URL을 읽어 SUPABASE_URL 로 주입합니다.
# SUPABASE_URL=https://xxxx.supabase.co
# 신규 API 키(대시보드 API Keys) — sb_publishable_… (있으면 이쪽이 우선)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# 또는 NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# 레거시 anon JWT (Publishable 없을 때)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# 서버 전용: 레거시 service_role JWT 또는 신규 sb_secret_…
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_SECRET_KEY=sb_secret_...

# npm run db:apply — 권장: Session pool (IPv4·6543). 직접 db.*.supabase.co:5432 는 IPv6만 있어 회선에 따라 타임아웃됨.
# 대시보드 → Database → Connection string → Method **Session pool** → URI 복사
# DATABASE_URL=postgresql://postgres.bxkaqwrqcflycqdlzsoz:[DB비밀번호]@aws-0-지역.pooler.supabase.com:6543/postgres
# Node DNS가 막힐 때(Windows): 선택
# DB_APPLY_DNS_SERVERS=8.8.8.8,1.1.1.1
# Supabase HTTP를 Node 기본 fetch만 쓰고 싶을 때(undici IPv4 끔)
# SUPABASE_FETCH_IPV4=0

# 라운드 업로드 토큰 해시용 (임의 긴 문자열)
UPLOAD_TOKEN_PEPPER=랜덤으로-길게-바꾸세요

NEXT_PUBLIC_CLUB_ID=default
